generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TruckLog {
  id        Int      @id @default(autoincrement())
  truckId   String   @map("truck_id")
  latitude  Float
  longitude Float
  timestamp DateTime @default(now())
  rfidTags  String   @default("[]") @map("rfid_tags")

  @@map("truck_logs")
}

model DUMH {
  id        Int      @id @default(autoincrement())
  name      String
  address   String
  latitude  Float
  longitude Float
  spots     Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  reservations Reservation[]
  alerts       Alert[]

  @@map("dumhs")
}

model Reservation {
  id        Int      @id @default(autoincrement())
  hubId     Int      @map("hub_id")
  truckId   String   @map("truck_id")
  startTime DateTime @map("start_time")
  endTime   DateTime @map("end_time")
  status    String   @default("active")
  createdAt DateTime @default(now()) @map("created_at")

  dumh DUMH @relation(fields: [hubId], references: [id])

  @@map("reservations")
}

model Alert {
  id        Int      @id @default(autoincrement())
  hubId     Int      @map("hub_id")
  type      String
  message   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  dumh DUMH @relation(fields: [hubId], references: [id])

  @@map("alerts")
}

model DeliveryNote {
  id               Int      @id @default(autoincrement())
  number           String   @unique @map("number")
  date             DateTime @default(now())
  supplier         String
  rfidTag          String?  @map("rfid_tag")
  type             String   @default("original")
  correctedNoteId  Int?     @map("corrected_note_id")
  fileName         String?  @map("file_name")
  weight           Float?
  volume           Float?
  productType      String?  @map("product_type")
  establishmentType String? @map("establishment_type")
  createdAt        DateTime @default(now()) @map("created_at")

  correctedNote DeliveryNote? @relation("CorrectionRelation", fields: [correctedNoteId], references: [id])
  corrections   DeliveryNote[] @relation("CorrectionRelation")

  @@map("delivery_notes")
}
