generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TruckLog {
  id        Int      @id @default(autoincrement())
  truckId   String   @map("truck_id")
  latitude  Float
  longitude Float
  timestamp DateTime @default(now())
  rfidTags  String   @default("[]") @map("rfid_tags")

  @@map("truck_logs")
}
